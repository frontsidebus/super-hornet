# =============================================================================
# Super Hornet Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------

# Anthropic API key for Claude inference (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ElevenLabs API key for text-to-speech (required for voice)
ELEVENLABS_API_KEY=your-key-here

# UEX Corp API bearer token (optional, increases rate limit)
UEX_API_KEY=

# -----------------------------------------------------------------------------
# Claude Settings
# -----------------------------------------------------------------------------

# Claude model to use for inference (haiku for speed, sonnet for quality)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Max tokens for Claude responses (lower = faster, more tactical)
CLAUDE_MAX_TOKENS=512

# Max tokens for briefings, trade plans, and detailed responses
CLAUDE_MAX_TOKENS_BRIEFING=2048

# Max message pairs to retain in conversation history
CLAUDE_MAX_HISTORY=20

# -----------------------------------------------------------------------------
# Star Citizen
# -----------------------------------------------------------------------------

# Path to Star Citizen game.log file
# Windows default: C:\Program Files\Roberts Space Industries\StarCitizen\LIVE\game.log
SC_GAME_LOG_PATH=

# Path to Star Citizen installation (for static data extraction)
# Windows default: C:\Program Files\Roberts Space Industries\StarCitizen
SC_INSTALL_PATH=

# -----------------------------------------------------------------------------
# UEX Corp API
# -----------------------------------------------------------------------------

# UEX Corp API base URL (default: https://uexcorp.space/api/2.0)
# UEX_API_BASE_URL=https://uexcorp.space/api/2.0

# -----------------------------------------------------------------------------
# Vision Pipeline
# -----------------------------------------------------------------------------

# Enable vision-based HUD reading via screen capture
VISION_ENABLED=true

# Vision capture frames per second
VISION_FPS=1

# Path to ROI definitions YAML for HUD element regions
# VISION_ROI_CONFIG_PATH=data/vision_rois.yaml

# -----------------------------------------------------------------------------
# Input Simulation
# -----------------------------------------------------------------------------

# Enable keyboard/mouse input simulation (requires user opt-in)
# WARNING: This allows the AI to send keystrokes to Star Citizen.
# Only enable if you understand what this does.
INPUT_SIMULATION_ENABLED=false

# -----------------------------------------------------------------------------
# Voice Pipeline -- Speech-to-Text (faster-whisper)
# -----------------------------------------------------------------------------

# faster-whisper model: tiny, base, small, medium, large-v3 (medium recommended)
WHISPER_MODEL=medium

# URL of the local faster-whisper HTTP service
# WHISPER_URL=http://localhost:9090

# -----------------------------------------------------------------------------
# Voice Pipeline -- Text-to-Speech (ElevenLabs)
# -----------------------------------------------------------------------------

# ElevenLabs voice ID for Super Hornet's voice
ELEVENLABS_VOICE_ID=

# ElevenLabs model ID
# eleven_flash_v2_5 for low latency, eleven_multilingual_v2 for quality
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# -----------------------------------------------------------------------------
# ChromaDB (Knowledge Base + Skill Library)
# -----------------------------------------------------------------------------

# URL of the ChromaDB HTTP server (Docker)
# CHROMADB_URL=http://localhost:8000

# Collection names (defaults are fine for most setups)
# KNOWLEDGE_BASE_COLLECTION=hornet_knowledge
# SKILL_LIBRARY_COLLECTION=hornet_skills

# -----------------------------------------------------------------------------
# Screen Capture
# -----------------------------------------------------------------------------

# Enable screen capture for vision-based analysis
SCREEN_CAPTURE_ENABLED=false

# Frames per second for screen capture
SCREEN_CAPTURE_FPS=1

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
